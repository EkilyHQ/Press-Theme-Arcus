{
  "schemaVersion": 1,
  "decision": "reviewed-exact-fingerprint-baseline-with-zero-growth",
  "scope": ["theme/**/*.js", "theme/**/*.mjs"],
  "rationale": "Arcus intentionally renders Press-sanitized content, reviewed Press renderer output, and owned escaped or static templates. Exact semantic fingerprints pin each write or wrapper call to its full lexical owner and full-file AST path so equivalent source cannot move between contexts without review.",
  "wrappers": [
    {
      "name": "applyOptions",
      "rationale": "applyOptions is Arcus's local theme-pack option wrapper; each caller is fingerprinted because the helper clears a live select before rebuilding sanitized value and text option nodes through DOM APIs."
    },
    {
      "name": "clearArcusToc",
      "rationale": "clearArcusToc is Arcus's reviewed TOC reset wrapper; each caller is fingerprinted because the helper can reach the live DOM through a component clear method or a constant empty-string fallback."
    },
    {
      "name": "populateThemePackOptions",
      "rationale": "populateThemePackOptions is Arcus's currently dormant theme-pack option wrapper; retaining it in policy ensures any future call site becomes explicit sink growth even though its existing clear is already fingerprinted."
    },
    {
      "name": "renderFooterLinks",
      "rationale": "renderFooterLinks is Arcus's reviewed footer navigation wrapper; it accepts only router-produced hrefs and escapes both every href and visible label before insertion."
    },
    {
      "name": "renderLinksList",
      "rationale": "renderLinksList is Arcus's reviewed profile-link wrapper; it sanitizes each URL and escapes every URL attribute and visible label before insertion."
    },
    {
      "name": "renderLoader",
      "rationale": "renderLoader is Arcus's reviewed loading-state wrapper; it inserts a source-owned skeleton and escapes the translated status message."
    },
    {
      "name": "renderNavLinks",
      "rationale": "renderNavLinks is Arcus's reviewed primary-navigation wrapper; it escapes slugs, router-produced hrefs, and labels before insertion."
    },
    {
      "name": "renderStaticView",
      "rationale": "renderStaticView is Arcus's reviewed static-tab wrapper; it escapes the heading and accepts the tab body only from Press's rendered-content boundary."
    },
    {
      "name": "resetToolsPanel",
      "rationale": "resetToolsPanel is Arcus's reviewed theme-control reset wrapper; it performs only a constant empty clear before delegating to the trusted Press controls mount."
    },
    {
      "name": "setupToolsPanel",
      "rationale": "setupToolsPanel is Arcus's reviewed theme-control wrapper; its only direct write is a constant empty clear when controls are disabled, otherwise it mounts the trusted Press component."
    },
    {
      "name": "showToc",
      "rationale": "showToc is Arcus's reviewed table-of-contents wrapper; it escapes the local title and accepts tocHtml only from Press's rendered TOC boundary."
    }
  ],
